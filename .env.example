# OpenWeatherMap API key. Required at build and runtime.
VITE_OPENWEATHER_API_KEY=

# Optional: override the OpenWeatherMap host (defaults to https://api.openweathermap.org).
# The app appends /data/2.5 for weather and /geo/1.0 for city search.
# VITE_OPENWEATHER_API_HOST=https://api.openweathermap.org
